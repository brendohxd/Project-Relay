{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-relay.dev/schemas/task.schema.json",
  "title": "Relay Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "question",
    "state",
    "risk",
    "owner",
    "reviewers",
    "created_at",
    "inputs",
    "acceptance_criteria",
    "constraints"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]{1,31}-[0-9]{4,}$" },
    "title": { "type": "string", "minLength": 3, "maxLength": 160 },
    "question": { "type": "string", "minLength": 10, "maxLength": 2000 },
    "state": {
      "enum": [
        "draft",
        "ready",
        "claimed",
        "in_progress",
        "submitted",
        "under_review",
        "remediation",
        "accepted",
        "rejected",
        "blocked",
        "cancelled"
      ]
    },
    "risk": { "enum": ["low", "moderate", "high", "critical"] },
    "owner": { "$ref": "#/$defs/actor" },
    "reviewers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/actor" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["uri", "description"],
        "properties": {
          "uri": { "type": "string", "minLength": 1, "maxLength": 2000 },
          "description": { "type": "string", "minLength": 1, "maxLength": 500 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "media_type": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 3, "maxLength": 1000 }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 3, "maxLength": 1000 }
    },
    "labels": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,49}$" }
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "role"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{1,127}$" },
        "type": { "enum": ["human", "model", "service"] },
        "role": { "type": "string", "minLength": 2, "maxLength": 100 },
        "provider": { "type": "string", "minLength": 1, "maxLength": 100 },
        "model": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    }
  }
}
